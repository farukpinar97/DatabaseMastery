@model List<ResultTestimonialDto>

<style>
    .swiper-group-3-customers .swiper-wrapper {
        align-items: stretch;
    }

    .swiper-group-3-customers .swiper-slide {
        height: auto;
    }

    .card-testimonial-grid {
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

        .card-testimonial-grid p {
            flex: 1;
        }
</style>

<section class="section mt-50 bg-customers-say">
    <div class="container">
        <h2 class="title-favicon color-white mb-20 title-padding-left">Müşterilerimiz bizim için neler söyledi ?</h2>
        <p class="font-lg color-white pl-55">
            Hizmetlerimizden faydalanan müşterilerimizin lojistik süreçlerinde elde ettikleri
            <br class="d-none d-lg-block">hız, güven ve verimlilik deneyimlerini keşfedin.
        </p>
    </div>
    <div class="box-slide-customers mt-50">
        <div class="box-swiper">
            <div class="swiper-container swiper-group-3-customers pb-50">
                <div class="swiper-wrapper">
                    @foreach (var item in Model)
                    {
                        int fullStars = (int)Math.Floor((double)item.ReviewScore);
                        bool hasHalf = (item.ReviewScore - fullStars) >= 0.5;
                        int emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

                        <div class="swiper-slide">
                            <div class="card-testimonial-grid">

                                <div class="box-author mb-25">
                                    <a href="#">
                                        <img src="@item.ImageUrl" alt="@item.NameSurname">
                                    </a>
                                    <div class="author-info">
                                        <a href="#">
                                            <span class="font-xl-bold color-brand-2 author-name">@item.NameSurname</span>
                                        </a>
                                        <span class="font-sm color-grey-500 department">@item.Title</span>
                                    </div>
                                </div>

                                <p class="font-md color-grey-700">@item.ReviewDetail</p>

                                <div class="card-bottom-info justify-content-between">
                                    <div class="rating text-start">
                                        @for (int i = 0; i < fullStars; i++)
                                        {
                                            <img src="/templates/assets/imgs/template/icons/star.svg" alt="dolu yıldız">
                                        }
                                        @if (hasHalf)
                                        {
                                            <img src="/templates/assets/imgs/template/icons/star-half.svg" alt="yarım yıldız">
                                        }
                                        @for (int i = 0; i < emptyStars; i++)
                                        {
                                            <img src="/templates/assets/imgs/template/icons/star-gray.svg" alt="boş yıldız">
                                        }
                                        <br>
                                        <span class="font-sm color-white">Müşteri Değerlendirmesi</span>
                                    </div>
                                    <span class="font-xs color-grey-500 rate-post text-end">Puan: @item.ReviewScore / 5</span>
                                </div>

                            </div>
                        </div>
                    }
                </div>

                <div class="box-pagination-customers">
                    <div class="swiper-button-prev swiper-button-prev-customers swiper-button-prev-style-1">
                        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
                        </svg>
                    </div>
                    <div class="swiper-button-next swiper-button-next-customers swiper-button-next-style-1">
                        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
                        </svg>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>